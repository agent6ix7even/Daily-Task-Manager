{
  "name": "@workspace/daily-tasks-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Дневник задач — автономное настольное приложение",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "pnpm run build:renderer && pnpm run build:electron",
    "dist:win": "pnpm run build && electron-builder --win --x64",
    "dist:mac": "pnpm run build && electron-builder --mac",
    "dist:linux": "pnpm run build && electron-builder --linux",
    "dist:all": "pnpm run build && electron-builder --win --x64 --mac --linux",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p electron/tsconfig.json"
  },
  "dependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.3",
    "vite": "catalog:"
  }
}
